<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="@color/white"
    android:layout_height="match_parent"

    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/health_and_wellness_app"
            android:textSize="25sp"
            android:textAlignment="center"
            android:layout_marginTop="30dp"
            android:id="@+id/title"
            android:textColor="#5CEB6A"
            android:textStyle="bold"

            />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/image2"
            android:scaleType="centerCrop"
            android:layout_margin="20dp"
            android:id="@+id/image"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="18dp"
            android:text="@string/healthy_recipes"
            android:textSize="20sp"
            android:id="@+id/recipes"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="18dp"
            android:textSize="20sp"
            android:text="@string/nutrition_advice"
            android:id="@+id/nutrition"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="18dp"
            android:textSize="20sp"
            android:text="@string/meditation"
            android:id="@+id/meditation"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:text="@string/hydration_alert"
            android:layout_margin="18dp"
            android:id="@+id/hydration"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/start_exercise"
            android:textSize="20sp"
            android:layout_margin="18dp"
            android:id="@+id/start"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/daily_motivation"
            android:textSize="20sp"
            android:layout_margin="15dp"
            android:id="@+id/Motivation"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />













    </LinearLayout>


</ScrollView>