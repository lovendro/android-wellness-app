<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:background="#161414"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:orientation="vertical"
        android:layout_height="wrap_content">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Health and wellness app"
            android:textSize="30sp"
            android:textAlignment="center"
            android:layout_marginTop="30dp"
            android:id="@+id/title"
            android:textColor="#5CEB6A"
            android:fontFamily="casual"

            />

        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/image2"
            android:scaleType="centerCrop"
            android:layout_margin="20dp"
            android:id="@+id/image"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            android:text="Healthy recipes"
            android:textSize="20sp"
            android:id="@+id/recipes"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            android:textSize="20sp"
            android:text="Nutrition advice"
            android:id="@+id/nutrition"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="15dp"
            android:textSize="20sp"
            android:text="Meditation"
            android:id="@+id/meditation"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="20sp"
            android:text="Hydration alert"
            android:layout_margin="15dp"
            android:id="@+id/hydration"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Start exercise"
            android:textSize="20sp"
            android:layout_margin="15dp"
            android:id="@+id/exercise"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Daily Motivation"
            android:textSize="20sp"
            android:layout_margin="15dp"
            android:id="@+id/Motivation"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Check progress"
            android:textSize="20sp"
            android:layout_margin="15dp"
            android:id="@+id/progress"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />

        <Button
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weekly goals"
            android:textSize="20sp"
            android:layout_margin="15dp"
            android:id="@+id/goals"
            android:backgroundTint="#24DC17"
            android:textColor="@color/white"
            />













    </LinearLayout>


</ScrollView>